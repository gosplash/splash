// Multi-file module example.
// Demonstrates: importing types from a sibling module with `use`.
//
// `use types` loads types.splash from the same directory.
// SearchResult and SearchQuery are defined there — not here.
// The compiler resolves the import, type-checks both files, and
// emits a single Go package containing all declarations.
//
// Run: splash check examples/multi_file/agent.splash
//      splash emit  examples/multi_file/agent.splash

module agent

use types

/// Search the catalog and return matching results.
tool fn search(query: types.SearchQuery) needs DB.read -> types.SearchResult {
    return types.SearchResult { title: query.text, url: "https://example.com", score: 1 }
}

/// Entry point for the search agent. Namespaced access makes ownership explicit.
agent fn run_search(text: String) needs DB.read -> types.SearchResult {
    let q = types.SearchQuery { text: text, limit: 10 }
    return search(q)
}
