// Agent control-plane example.
// Demonstrates: tool fn syntax, agent fn entry points, and authority boundaries.
//
// tool fn turns a function into an AI-callable tool. The doc comment becomes
// the tool description. The type signature becomes the JSON schema. The
// function is the implementation — one source of truth for all three.

module search

type SearchResult {
    id:    Int
    title: String
}

// tool fn: callable by any AI agent in a Splash runtime.
// limit has a default value of 10.
tool fn search_catalog(query: String, limit: Int) needs DB.read -> SearchResult {
    return SearchResult { id: limit, title: query }
}

// tool fn with an optional parameter. The schema reflects the optionality.
// Agents can call this with or without a category filter.
tool fn get_item(item_id: Int, category: String?) needs DB.read -> SearchResult {
    return SearchResult { id: item_id, title: "result" }
}

// redline fn: the compiler traces every path from every agent entry point.
// If any path reaches this function, the build fails.
// Index rebuilds require a human operator, not an automated agent.
redline(reason: "Index rebuilds require human operator sign-off") fn rebuild_search_index() needs DB.write {
    let op = "rebuild"
}

// Agent entry point. agent fn marks the boundary directly.
// The compiler verifies:
//   - search_catalog and get_item are reachable and safe (DB.read only)
//   - rebuild_search_index is NOT reachable (redline fn blocks the path)
//   - no reachable function requires more than the declared effects
agent fn run_search_agent(goal: String) needs DB.read -> String {
    let results = search_catalog(goal, 5)
    return goal
}
